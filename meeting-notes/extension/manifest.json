{
  "manifest_version": 3,
  "name": "Meeting Notes Taker",
  "version": "1.0.0",
  "description": "Capture meeting tab + mic audio, transcribe locally with Whisper, and generate structured notes with Claude.",
  "permissions": ["tabCapture", "offscreen", "activeTab", "storage", "sidePanel"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Meeting Notes Taker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
