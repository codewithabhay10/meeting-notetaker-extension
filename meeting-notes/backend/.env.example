# Copy this file to `.env` and fill in your key.
# The backend reads these on startup.

# Required for /summarize (Phase 4). Never put this in extension code.
ANTHROPIC_API_KEY=

# faster-whisper model. Safe defaults for a 4 GB GPU (RTX 3050): small.en or base.en.
# You can override to medium.en / medium if you have headroom.
WHISPER_MODEL=small.en

# Device: auto | cuda | cpu  (default auto).
# "auto" safely probes CUDA in a subprocess and falls back to CPU if cuDNN/driver
# is missing. Set to "cuda" to force GPU (needs CUDA 12 + cuDNN 9 on PATH), or
# "cpu" to force CPU.
WHISPER_DEVICE=auto

# Optional compute type override (default: float16 on cuda, int8 on cpu).
# Examples: int8, int8_float16, float16, float32
# WHISPER_COMPUTE_TYPE=

# Which LLM /summarize uses: anthropic (default) | ollama | gemini
SUMMARY_PROVIDER=anthropic

# Claude model used when SUMMARY_PROVIDER=anthropic.
# Swap to claude-haiku-4-5-20251001 for lower cost.
SUMMARY_MODEL=claude-sonnet-4-6

# --- Google Gemini (used only when SUMMARY_PROVIDER=gemini) ---
# FREE tier. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local Ollama settings (used only when SUMMARY_PROVIDER=ollama).
# Zero-cost notes with no API key. Requires `ollama serve` + `ollama pull llama3.1:8b`.
# Use 127.0.0.1 (not localhost) on Windows to avoid IPv6 (::1) resolution timeouts.
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3.1:8b
