# Copy this file to `.env` and fill in your key.
# The backend reads these on startup.

# Required for /summarize (Phase 4). Never put this in extension code.
ANTHROPIC_API_KEY=

# faster-whisper model. Safe defaults for a 4 GB GPU (RTX 3050): small.en or base.en.
# You can override to medium.en / medium if you have headroom.
WHISPER_MODEL=small.en

# Claude model used by /summarize. Swap to claude-haiku-4-5-20251001 for lower cost.
SUMMARY_MODEL=claude-sonnet-4-6
